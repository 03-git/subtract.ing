#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-or-later
# subtract CLI
# usage: subtract [command]
#   upgrade  - add optional tiers (local inference, cloud)
#   about    - what subtract is
#   help     - this message

SUBTRACT_DIR="$HOME/.subtract"

STATE_FILE="$SUBTRACT_DIR/.state"

__state_write() {
    local key="$1" value="$2"
    mkdir -p "$(dirname "$STATE_FILE")"
    if [ -f "$STATE_FILE" ]; then
        grep -v "^${key}=" "$STATE_FILE" > "${STATE_FILE}.tmp" 2>/dev/null || true
        mv "${STATE_FILE}.tmp" "$STATE_FILE"
    fi
    echo "${key}=${value}" >> "$STATE_FILE"
}

case "${1:-help}" in
    config)
        case "${2:-}" in
            --no-nags)
                __state_write "no_nags" "true"
                echo "Upgrade suggestions silenced."
                ;;
            --reset-nags)
                __state_write "no_nags" "false"
                __state_write "suggested" "false"
                __state_write "misses" "0"
                echo "Upgrade suggestion state reset."
                ;;
            *)
                echo "subtract config"
                echo ""
                echo "Options:"
                echo "  --no-nags     Silence upgrade suggestions"
                echo "  --reset-nags  Reset suggestion state"
                ;;
        esac
        ;;
    upgrade)
        echo ""
        echo "subtract upgrade"
        echo ""
        echo "Current: T0 (lookup table) + T0.5 (man pages)"
        echo ""
        echo "Optional tiers:"
        echo "  [1] Local inference (905MB) — T1+T2, reasoning"
        echo "  [2] Voice input (150MB) — T-Voice, whisper.cpp"
        echo "  [3] Voice output (50MB) — T-Ear, piper-tts"
        echo "  [4] Voice bundle (200MB) — T-Voice + T-Ear"
        echo "  [5] Cloud escalation — T4, requires API key"
        echo "  [6] Cancel"
        echo ""
        read -p "Choice: " choice

        case "$choice" in
            1)
                echo ""
                echo "Installing local inference (T1+T2)..."
                echo ""
                echo "T1+T2 requires llama.cpp and two models."
                echo ""
                echo "Get llama.cpp:"
                echo "  https://github.com/ggerganov/llama.cpp/releases"
                echo ""
                echo "Download models:"
                echo "  mkdir -p ~/.subtract/models"
                echo ""
                echo "  # T1 embedding (~45MB)"
                echo "  curl -L -o ~/.subtract/models/nomic-embed.gguf \\"
                echo "    https://huggingface.co/nomic-ai/nomic-embed-text-v1.5-GGUF/resolve/main/nomic-embed-text-v1.5.Q4_K_M.gguf"
                echo ""
                echo "  # T2 reasoning (~850MB)"
                echo "  curl -L -o ~/.subtract/models/qwen2.5-1.5b.gguf \\"
                echo "    https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf"
                echo ""
                mkdir -p "$SUBTRACT_DIR/models"
                echo "qwen2.5-1.5b.gguf" > "$SUBTRACT_DIR/model"
                echo "nomic-embed.gguf" > "$SUBTRACT_DIR/embed"
                echo "T1+T2 configured. Install llama.cpp and models to activate."
                ;;
            2)
                echo ""
                echo "Installing voice input (T-Voice)..."
                echo ""
                echo "T-Voice requires whisper.cpp and a model."
                echo ""
                echo "Get whisper.cpp:"
                echo "  https://github.com/ggerganov/whisper.cpp/releases"
                echo ""
                echo "Download model (~150MB):"
                echo "  mkdir -p ~/.subtract/models"
                echo "  curl -L -o ~/.subtract/models/ggml-base.en.bin \\"
                echo "    https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin"
                echo ""
                mkdir -p "$SUBTRACT_DIR/models"
                echo "whisper" > "$SUBTRACT_DIR/voice"
                echo "T-Voice configured. Download whisper.cpp and model to activate."
                ;;
            3)
                echo ""
                echo "Installing voice output (T-Ear)..."
                echo ""
                echo "T-Ear requires piper-tts."
                echo ""
                echo "Get piper:"
                echo "  https://github.com/rhasspy/piper/releases"
                echo ""
                echo "Download voice model (~50MB):"
                echo "  mkdir -p ~/.subtract/models"
                echo "  curl -L -o ~/.subtract/models/en_US-lessac-medium.onnx \\"
                echo "    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx"
                echo ""
                mkdir -p "$SUBTRACT_DIR/models"
                echo "piper" > "$SUBTRACT_DIR/ear"
                echo "T-Ear configured. Download piper and model to activate."
                ;;
            4)
                echo ""
                echo "Installing voice bundle (T-Voice + T-Ear)..."
                echo ""
                echo "Voice bundle requires whisper.cpp and piper-tts."
                echo ""
                echo "Get binaries:"
                echo "  https://github.com/ggerganov/whisper.cpp/releases"
                echo "  https://github.com/rhasspy/piper/releases"
                echo ""
                echo "Download models (~200MB total):"
                echo "  mkdir -p ~/.subtract/models"
                echo "  curl -L -o ~/.subtract/models/ggml-base.en.bin \\"
                echo "    https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin"
                echo "  curl -L -o ~/.subtract/models/en_US-lessac-medium.onnx \\"
                echo "    https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx"
                echo ""
                mkdir -p "$SUBTRACT_DIR/models"
                echo "whisper" > "$SUBTRACT_DIR/voice"
                echo "piper" > "$SUBTRACT_DIR/ear"
                echo "Voice bundle configured. Download binaries and models to activate."
                ;;
            5)
                echo ""
                echo "Cloud escalation (T4) uses curl to call inference APIs."
                echo ""
                echo "Option A — Claude subscription (if you have Max/Pro):"
                echo "  claude auth login"
                echo ""
                echo "Option B — API key (pay-per-token):"
                echo "  export ANTHROPIC_API_KEY=sk-ant-..."
                echo ""
                echo "  # T4 calls the API directly:"
                echo "  curl -s https://api.anthropic.com/v1/messages \\"
                echo "    -H \"x-api-key: \$ANTHROPIC_API_KEY\" \\"
                echo "    -H \"anthropic-version: 2023-06-01\" \\"
                echo "    -H \"content-type: application/json\" \\"
                echo "    -d '{\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":256,\"messages\":[{\"role\":\"user\",\"content\":\"translate to bash: show my files\"}]}'"
                echo ""
                echo "No pip. No npm. Just curl."
                echo ""
                echo "T4 activates when T0/T1/T2 can't handle the query."
                mkdir -p "$SUBTRACT_DIR"
                echo "curl" > "$SUBTRACT_DIR/cloud"
                echo "T4 configured."
                ;;
            6|*)
                echo "Cancelled."
                ;;
        esac
        ;;
    about)
        if [ -f "$SUBTRACT_DIR/about" ]; then
            cat "$SUBTRACT_DIR/about"
        else
            echo "subtract: a shell that does what you mean"
            echo "https://subtract.ing"
        fi
        ;;
    help|*)
        echo "subtract — type what you want, see the command, confirm"
        echo ""
        echo "Commands:"
        echo "  upgrade  Add optional tiers (inference, voice, cloud)"
        echo "  config   Settings (--no-nags, --reset-nags)"
        echo "  about    What subtract is"
        echo "  help     This message"
        echo ""
        echo "Tiers:"
        echo "  T0      Lookup table (active)"
        echo "  T0.5    Man pages (active)"
        echo "  T1      Embedding similarity (subtract upgrade)"
        echo "  T2      Local model (subtract upgrade)"
        echo "  T-Voice Voice input (subtract upgrade)"
        echo "  T-Ear   Voice output (subtract upgrade)"
        echo "  T4      Cloud escalation (subtract upgrade)"
        ;;
esac
