#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-or-later
# subtract - shell + API + docs, side by side

SUBTRACT_DIR="$HOME/.subtract"

case "${1:-start}" in
    start|"")
        # Check for tmux
        if ! command -v tmux &>/dev/null; then
            echo "subtract requires tmux"
            echo "  macOS: brew install tmux"
            echo "  Linux: apt install tmux"
            exit 1
        fi

        # Check for claude
        if ! command -v claude &>/dev/null; then
            echo "subtract requires claude CLI"
            echo "  https://docs.anthropic.com/en/docs/claude-code"
            exit 1
        fi

        session="subtract"

        # Attach to existing session if present
        tmux attach -t "$session" 2>/dev/null && exit 0

        # Docs: local navigation cheatsheet (user presses 'g' to go elsewhere)
        URL="$SUBTRACT_DIR/index.html"

        # Get terminal dimensions
        COLS=$(tput cols)

        # Create session with three panes
        if [[ $COLS -lt 100 ]]; then
            # Narrow: stack vertical
            tmux new-session -d -s "$session"
            tmux split-window -v -t "$session"
            tmux split-window -v -t "$session"
        else
            # Wide: horizontal thirds
            tmux new-session -d -s "$session"
            tmux split-window -h -p 66 -t "$session"
            tmux split-window -h -p 50 -t "$session"
        fi

        # Enable mouse mode
        tmux set-option -t "$session" mouse on

        # Pane bindings: ctrl-b 1/2/3
        tmux bind-key -T prefix 1 select-pane -t 0
        tmux bind-key -T prefix 2 select-pane -t 1
        tmux bind-key -T prefix 3 select-pane -t 2

        # WSL clipboard integration: Ctrl+C to copy, Ctrl+V to paste
        if [ -f /mnt/c/Windows/System32/clip.exe ]; then
            tmux bind-key -T copy-mode C-c send-keys -X copy-pipe-and-cancel "/mnt/c/Windows/System32/clip.exe"
            tmux bind-key -T copy-mode-vi C-c send-keys -X copy-pipe-and-cancel "/mnt/c/Windows/System32/clip.exe"
            tmux bind-key -n C-v run "tmux set-buffer \"\$(/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -command '[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Clipboard' | tr -d '\\r')\" && tmux paste-buffer"
        fi

        # Pane 0 (shell): cheatsheet then prompt
        if [ -f "$SUBTRACT_DIR/cheatsheet.txt" ]; then
            tmux send-keys -t "$session:0.0" "clear && cat $SUBTRACT_DIR/cheatsheet.txt && echo ''" C-m
        fi

        # Pane 1 (API): launch claude
        tmux send-keys -t "$session:0.1" 'claude' C-m

        # Pane 2 (docs): lynx to docs URL
        tmux send-keys -t "$session:0.2" "lynx $URL" C-m

        # Attach
        tmux attach -t "$session"
        ;;
    help|*)
        echo "subtract — shell + API + docs, side by side"
        echo "  subtract      launch environment"
        echo "  subtract help this message"
        ;;
esac
